$C = "../Common.ui";

@PrimaryButtonStyle = TextButtonStyle(
  Default: (Background: #3a7bd5, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4a8be5, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a6bc5, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@SecondaryBtnStyle = TextButtonStyle(
  Default: (Background: #2b3542, LabelStyle: (FontSize: 14, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3b4552, LabelStyle: (FontSize: 14, TextColor: #b6c9de, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1b2532, LabelStyle: (FontSize: 14, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

$C.@PageOverlay {

  $C.@Container {
    Anchor: (Width: 900, Height: 520);
    Padding: (Full: 0);

    #Content {
      LayoutMode: Left;

      // LEFT SIDEBAR
      Group #Sidebar {
        Anchor: (Width: 180);
        Background: #0f1a24;
        Padding: (Top: 20, Left: 10, Right: 10);

        Label {
          Text: "ENDLESS";
          Style: (FontSize: 12, TextColor: #6e7da1);
        }

        Label {
          Text: "LEVELING";
          Style: (FontSize: 18, RenderBold: true, TextColor: #ffffff);
        }

        Group { Anchor: (Height: 20); }

        Label { Text: "PROFILE"; Style:(FontSize:13,TextColor:#96a9be); }
        Group { Anchor: (Height: 10); }

        Label { Text: "SKILLS"; Style:(FontSize:13,TextColor:#96a9be); }
        Group { Anchor: (Height: 10); }

        Label { Text: "AUGMENTS"; Style:(FontSize:13,TextColor:#96a9be); }
        Group { Anchor: (Height: 10); }

        Label { Text: "RACES"; Style:(FontSize:13,TextColor:#96a9be); }
        Group { Anchor: (Height: 10); }

        Label { Text: "CLASSES"; Style:(FontSize:13,TextColor:#96a9be); }
        Group { Anchor: (Height: 10); }

        Label { Text: "LEADERBOARDS"; Style:(FontSize:13,TextColor:#96a9be); }

        Group { FlexWeight: 1; }

        Label {
          Text: "SETTINGS";
          Style: (FontSize: 13, RenderBold: true, TextColor: #ffffff);
        }
      }

      // RIGHT MAIN CONTENT
      Group #Main {
        FlexWeight: 1;
        Padding: (Top: 20, Left: 20, Right: 20, Bottom: 20);
        LayoutMode: Top;

        Label {
          Text: "Settings";
          Style: (FontSize: 20, RenderBold: true, TextColor: #ffffff);
        }

        Group { Anchor: (Height: 15); }

        Group #SettingsList {
          LayoutMode: TopScrolling;
          FlexWeight: 1;
          ScrollbarStyle: $C.;@DefaultScrollbarStyle;

          // ===== SETTING ROW TEMPLATE =====

          // PLAYER HUD
          Group {
            Anchor: (Height: 70);
            Background: #1c2733;
            Padding: (Left: 15, Right: 15);
            LayoutMode: Left;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label {
                Text: "Player HUD";
                Style:(FontSize:14,RenderBold:true,TextColor:#ffffff);
              }

              Label {
                Text: "Show or hide the HUD overlay.";
                Style:(FontSize:11,TextColor:#96a9be);
              }
            }

            Label #HudState {
              Text: "ON";
              Style:(FontSize:13,TextColor:#55FF55,RenderBold:true);
              Anchor:(Width:40);
            }

            TextButton #HudToggle {
              Text: "TOGGLE";
              Anchor:(Width:110,Height:36);
              Style: @PrimaryButtonStyle;
            }
          }

          Group { Anchor:(Height:10); }

          // CRITICAL
          Group {
            Anchor:(Height:70);
            Background:#1c2733;
            Padding:(Left:15,Right:15);
            LayoutMode: Left;

            Group { FlexWeight:1; LayoutMode:Top;
              Label { Text:"Critical Hit Notifications"; Style:(FontSize:14,RenderBold:true,TextColor:#ffffff); }
              Label { Text:"Show critical hit alerts."; Style:(FontSize:11,TextColor:#96a9be); }
            }

            Label #CritState { Text:"ON"; Style:(FontSize:13,TextColor:#55FF55,RenderBold:true); Anchor:(Width:40); }

            TextButton #CritToggle { Text:"TOGGLE"; Anchor:(Width:110,Height:36); Style:@PrimaryButtonStyle; }
          }

          Group { Anchor:(Height:10); }

          // XP
          Group {
            Anchor:(Height:70);
            Background:#1c2733;
            Padding:(Left:15,Right:15);
            LayoutMode: Left;

            Group { FlexWeight:1; LayoutMode:Top;
              Label { Text:"XP Gain Notifications"; Style:(FontSize:14,RenderBold:true,TextColor:#ffffff); }
              Label { Text:"Show XP gain alerts."; Style:(FontSize:11,TextColor:#96a9be); }
            }

            Label #XpState { Text:"ON"; Style:(FontSize:13,TextColor:#55FF55,RenderBold:true); Anchor:(Width:40); }

            TextButton #XpToggle { Text:"TOGGLE"; Anchor:(Width:110,Height:36); Style:@PrimaryButtonStyle; }
          }

          Group { Anchor:(Height:10); }

          // PASSIVE
          Group {
            Anchor:(Height:70);
            Background:#1c2733;
            Padding:(Left:15,Right:15);
            LayoutMode: Left;

            Group { FlexWeight:1; LayoutMode:Top;
              Label { Text:"Passive Level-Up"; Style:(FontSize:14,RenderBold:true,TextColor:#ffffff); }
              Label { Text:"Show passive level updates."; Style:(FontSize:11,TextColor:#96a9be); }
            }

            Label #PassiveState { Text:"ON"; Style:(FontSize:13,TextColor:#55FF55,RenderBold:true); Anchor:(Width:40); }

            TextButton #PassiveToggle { Text:"TOGGLE"; Anchor:(Width:110,Height:36); Style:@PrimaryButtonStyle; }
          }

          Group { Anchor:(Height:10); }

          // LUCK
          Group {
            Anchor:(Height:70);
            Background:#1c2733;
            Padding:(Left:15,Right:15);
            LayoutMode: Left;

            Group { FlexWeight:1; LayoutMode:Top;
              Label { Text:"Luck Notifications"; Style:(FontSize:14,RenderBold:true,TextColor:#ffffff); }
              Label { Text:"Show bonus drop alerts."; Style:(FontSize:11,TextColor:#96a9be); }
            }

            Label #LuckState { Text:"ON"; Style:(FontSize:13,TextColor:#55FF55,RenderBold:true); Anchor:(Width:40); }

            TextButton #LuckToggle { Text:"TOGGLE"; Anchor:(Width:110,Height:36); Style:@PrimaryButtonStyle; }
          }

          Group { Anchor:(Height:10); }

          // REGEN
          Group {
            Anchor:(Height:70);
            Background:#1c2733;
            Padding:(Left:15,Right:15);
            LayoutMode: Left;

            Group { FlexWeight:1; LayoutMode:Top;
              Label { Text:"Health Regen"; Style:(FontSize:14,RenderBold:true,TextColor:#ffffff); }
              Label { Text:"Show regen notifications."; Style:(FontSize:11,TextColor:#96a9be); }
            }

            Label #RegenState { Text:"ON"; Style:(FontSize:13,TextColor:#55FF55,RenderBold:true); Anchor:(Width:40); }

            TextButton #RegenToggle { Text:"TOGGLE"; Anchor:(Width:110,Height:36); Style:@PrimaryButtonStyle; }
          }

          Group { Anchor:(Height:10); }

          // AUGMENT
          Group {
            Anchor:(Height:70);
            Background:#1c2733;
            Padding:(Left:15,Right:15);
            LayoutMode: Left;

            Group { FlexWeight:1; LayoutMode:Top;
              Label { Text:"Augment Notifications"; Style:(FontSize:14,RenderBold:true,TextColor:#ffffff); }
              Label { Text:"Show augment alerts."; Style:(FontSize:11,TextColor:#96a9be); }
            }

            Label #AugmentState { Text:"OFF"; Style:(FontSize:13,TextColor:#ff5555,RenderBold:true); Anchor:(Width:40); }

            TextButton #AugmentToggle { Text:"TOGGLE"; Anchor:(Width:110,Height:36); Style:@PrimaryButtonStyle; }
          }

        }
      }

    }

  }

}
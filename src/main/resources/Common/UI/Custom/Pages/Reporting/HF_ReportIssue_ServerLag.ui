$C = "../../Common.ui";

Group #ServerLagPage {
  Visible: false;
  LayoutMode: Top;

  Label { Style: (FontSize: 14, TextColor:#b4c8c9, RenderBold: true); Anchor: (Height: 10); Text: "Active Players During Event:"; }
  Group {Anchor: (Height: 15);}
  $C.@TextField #ActivePlayersInput { Anchor: (Height: 40); PlaceholderText: "Estimate the number of players..."; }
  Group {Anchor: (Height: 10);}

  Label { Style: (FontSize: 14, TextColor:#b4c8c9, RenderBold: true); Anchor: (Height: 10); Text: "Severity:"; }
  Group {Anchor: (Height: 15);}
  $C.@DropdownBox #LagSeverityDropdown {
    Anchor: (Height: 40); Value: "MINOR";
    DropdownEntry { Value: "MINOR"; Text: "Minor"; }
    DropdownEntry { Value: "MAJOR"; Text: "Major"; }
    DropdownEntry { Value: "UNPLAYABLE"; Text: "Unplayable"; }
  }
  Group {Anchor: (Height: 10);}

  Label { Style: (FontSize: 14, TextColor:#b4c8c9, RenderBold: true); Anchor: (Height: 10); Text: "Triggered When:"; }
  Group {Anchor: (Height: 15);}
  $C.@TextField #LagTriggerInput { Anchor: (Height: 40); PlaceholderText: "Did a specific action cause the lag?"; }
  Group {Anchor: (Height: 10);}
}
$C = "Common.ui";

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 560, Height: 420);

    #Title {
      $C.@Title {
        @Text = "Player Database";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);
      Gap: 10;

      // Header label (will be updated from Java)
      Label #playersCountText {
        Text: "PLAYERS (0)";
        Anchor: (Height: 22);
        Style: (FontSize: 14, TextColor: #FFFFFF(0.85));
      }

      // Scrollable list area. Java will append rows into #listContent.
      ScrollArea #listScroll {
        Anchor: (Height: 290);
        Background: #10101a(0.65);
        Padding: (Full: 10);
        LayoutMode: Top;

        Group #listContent {
          LayoutMode: Top;
          Gap: 8;
        }
      }

      // Footer buttons
      Group #footer {
        LayoutMode: Left;
        Anchor: (Height: 44);
        Gap: 10;

        TextButton #addPlayerBtn {
          Text: "+ Add Player";
          Anchor: (Width: 160, Height: 44);
          Style: $C.@DefaultTextButtonStyle;
        }

        TextButton #refreshBtn {
          Text: "Refresh";
          Anchor: (Width: 120, Height: 44);
          Style: $C.@DefaultTextButtonStyle;
        }

        // Spacer pushes Close to the right
        Group {
          Anchor: (Width: 1);
          Flex: (Grow: 1);
        }

        TextButton #closeBtn {
          Text: "Close";
          Anchor: (Width: 120, Height: 44);
          Style: $C.@DefaultTextButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}

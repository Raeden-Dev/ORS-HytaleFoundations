$C = "Common.ui";

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 560, Height: 420);

    #Title {
      $C.@Title {
        @Text = "Homes Database";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);
      Gap: 10;

      // Header row
      Group #headerRow {
        LayoutMode: Left;
        Anchor: (Height: 44);
        Gap: 10;

        Label #homesCountText {
          Text: "HOMES (0)";
          Anchor: (Height: 44);
          Style: (FontSize: 14, TextColor: #FFFFFF(0.85));
        }

        Group { Anchor: (Width: 1); Flex: (Grow: 1); }

        TextInput #searchInput {
          Placeholder: "Search homes...";
          Anchor: (Width: 220, Height: 44);
          Style: $C.@DefaultTextInputStyle;
        }
      }

      // Scrollable list
      ScrollArea #homesScroll {
        Anchor: (Height: 268);
        Background: #10101a(0.65);
        Padding: (Full: 10);
        LayoutMode: Top;

        Group #homesList {
          LayoutMode: Top;
          Gap: 8;
        }
      }

      // Footer buttons
      Group #footer {
        LayoutMode: Left;
        Anchor: (Height: 44);
        Gap: 10;

        TextButton #addHomeBtn {
          Text: "+ Add Home";
          Anchor: (Width: 160, Height: 44);
          Style: $C.@DefaultTextButtonStyle;
        }

        TextButton #importBtn {
          Text: "Import";
          Anchor: (Width: 120, Height: 44);
          Style: $C.@DefaultTextButtonStyle;
        }

        Group { Anchor: (Width: 1); Flex: (Grow: 1); }

        TextButton #closeBtn {
          Text: "Close";
          Anchor: (Width: 120, Height: 44);
          Style: $C.@DefaultTextButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
